@article{lemuria_general_2026,
	title = {General considerations when taxonomizing sewing patterns},
	rights = {Creative Commons Attribution-{ShareAlike} 4.0 International License},
	url = {https://lct01.lemuria.ph/articles/2026/2026.0004_general_considerations_sewing_patterns.html},
	abstract = {Sewing patterns define the shapes of cuts of fabric that are assembled to create garments. Much of the taxonomic work of the {LCT}-01 has gone into documenting individual home sewists’ makes of garments based on sewing patterns, whether from indie companies or larger well-known ones like Butterick and Simplicity. We seek to document the general procedures and considerations that we follow when taxonomizing sewing patterns, and document their parallels to biological taxonomy to ease the onboarding process.},
	journaltitle = {Lemuria's (Informal) Journal of Clothing Taxonomy},
	publisher = {Lemuria},
	author = {{Lemuria}},
	date = {2026-03-15},
	langid = {english},
}

